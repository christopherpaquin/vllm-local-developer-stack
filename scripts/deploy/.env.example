# =============================================================================
# deploy/.env.example — vLLM Deployment Configuration
# =============================================================================
#
# USAGE
# -----
# 1. Copy this file to deploy/.env:
#      cp deploy/.env.example deploy/.env
#
# 2. Edit deploy/.env — set at minimum:
#      BIND_HOST    — IP address to expose the API on (see notes below)
#      HF_CACHE_DIR — absolute path to your HuggingFace model cache
#
# 3. Run the deployment orchestrator:
#      bash scripts/deploy/deploy.sh
#
# deploy/.env is gitignored. Never commit it — it contains machine-specific
# paths and may contain authentication tokens.
#
# =============================================================================


# =============================================================================
# NETWORK — where the server listens
# =============================================================================

# BIND_HOST — which IP address on this host Docker binds the API port to.
#
# This controls which network interfaces other machines can reach the server on.
# It is the HOST-side binding in Docker's port mapping: BIND_HOST:PORT -> container:8000
# Inside the container, vLLM always binds 0.0.0.0 (all container interfaces).
#
# Common values:
#   0.0.0.0        → all host interfaces (LAN + loopback). Any machine that
#                    can reach this host will be able to call the API.
#   192.168.x.x    → a specific LAN interface only. Use this when you have
#                    multiple NICs and want to control which network is exposed.
#   127.0.0.1      → localhost only. No remote access.
#
# To find your primary LAN IP:
#   ip route get 1.1.1.1 | awk '{print $7; exit}'
#   hostname -I | awk '{print $1}'
#
# Security note: vLLM has no built-in authentication. If this host is directly
# internet-facing (no NAT/firewall), restrict access with a firewall rule or
# put a reverse proxy (nginx) in front before binding 0.0.0.0.
#
BIND_HOST=0.0.0.0

# TCP port for the OpenAI-compatible REST API.
# Clients connect to: http://BIND_HOST:PORT/v1/...
PORT=8000

# LAN_CIDR — the subnet CIDR of your private LAN. Used to restrict inbound firewall
# rules for vLLM and Open WebUI if ufw/firewalld is active.
# Leave blank to allow connections from any source IP (0.0.0.0/0).
# Example: LAN_CIDR=10.1.10.0/24 or LAN_CIDR=192.168.1.0/24
LAN_CIDR=10.1.10.0/24


# =============================================================================
# MODEL
# =============================================================================

# HuggingFace model ID — must exactly match the repository slug on HuggingFace Hub.
# This is also the model that will be downloaded to HF_CACHE_DIR on first run.
#
# Recommended for 2× RTX 3060 (24 GiB total VRAM) + code generation:
#   Qwen/Qwen2.5-Coder-32B-Instruct-AWQ
#   — Purpose-built for code generation (trained on 5.5T tokens of code)
#   — AWQ 4-bit quantization fits within 24 GiB with TP=2
#   — Supports up to 128K context (capped at 16K here for VRAM budget)
#   — Public model, no HF_TOKEN required
#
MODEL=Qwen/Qwen2.5-Coder-32B-Instruct-AWQ

# API alias — what clients put in the "model" field of their API requests.
# Avoids the slash in the HuggingFace ID that breaks some OpenAI-compatible clients.
# Must stay consistent with what scripts/deploy/setup-continue.sh configures.
SERVED_MODEL_NAME=qwen2.5-coder-32b-awq


# =============================================================================
# GPU PARALLELISM & TARGETING
# =============================================================================

# Number of GPUs for Tensor Parallelism (TP).
# vLLM shards model weights evenly across all TP GPUs.
#
# For 2× RTX 3060 (24 GiB total): TENSOR_PARALLEL_SIZE=2
#
# IMPORTANT — Qwen2.5-Coder-32B head geometry constraint:
#   num_key_value_heads = 8
#   Valid TP sizes: 1, 2, 4, 8  (must evenly divide 8)
#   Any other value causes a model load error inside the container.
#
TENSOR_PARALLEL_SIZE=2

# GPU_DEVICE_ID — specifies which GPUs Compose should allocate to the vLLM container.
# This aligns with the Docker Compose device request format.
#
# Common values:
#   nvidia.com/gpu=all     → exposes all available NVIDIA GPUs on the system
#   nvidia.com/gpu=0       → exposes only the first GPU
#   nvidia.com/gpu=0,1     → exposes specific GPUs (e.g. GPU 0 and 1)
#
GPU_DEVICE_ID=nvidia.com/gpu=all


# =============================================================================
# QUANTIZATION
# =============================================================================

# Must match the model variant downloaded above.
#   awq          → Activation-aware Weight Quantization  ← correct for this model
#   gptq         → GPTQ quantization
#   fp8          → FP8 (requires Hopper/Ada GPU — RTX 30xx/40xx NOT supported)
#   bitsandbytes → flexible but slower
QUANTIZATION=awq


# =============================================================================
# MEMORY & CONTEXT
# =============================================================================

# Fraction of each GPU's VRAM vLLM may allocate (model weights + KV cache).
# Range: 0.0–1.0.
#
# Recommended by GPU class:
#   ≤ 10 GiB  → 0.85  (conservative; ~1.5 GiB headroom)
#   12 GiB    → 0.90  (RTX 3060; ~1.2 GiB headroom per GPU)
#   ≥ 16 GiB  → 0.92
#
# Reduce by ~0.02 if a display server (X11/Wayland) is active on GPU 0.
# Run scripts/deploy/validate-system.sh to check idle VRAM usage.
#
GPU_MEMORY_UTILIZATION=0.90

# Maximum sequence length (prompt + completion tokens combined).
# KV cache VRAM usage scales linearly with this value.
#
# Safe limits by total cluster VRAM:
#   24 GiB (2× RTX 3060)  → 16384
#   32–48 GiB              → 32768
#   48+ GiB                → 65536
#
# Maximum model context length (tokens).
# For dual 12GB cards running a 32B model, this must be capped to prevent KV Cache OOMs.
# 6144 is the optimal balance between context window and VRAM limits (using eager mode).
#
# MAX_MODEL_LEN=16384

# CPU KV-cache swap (GiB). Offloads KV blocks to system RAM under memory pressure.
# Adds latency proportional to how often swapping is triggered.
#
# Set to 0 to disable. Only worth enabling when BOTH are true:
#   - System RAM ≥ 64 GiB
#   - HF_CACHE_DIR is on NVMe storage (not SATA SSD or spinning disk)
#
SWAP_SPACE=4


# =============================================================================
# HUGGINGFACE CACHE
# =============================================================================

# Absolute path on the host where model weights are stored.
# This directory is bind-mounted into the container as /root/.cache/huggingface.
# The Qwen2.5-Coder-32B-AWQ download is approximately 18 GiB — ensure the
# target device has sufficient free space before running deploy.sh.
#
# Use an ABSOLUTE path. Tilde (~) expansion is user-dependent and may resolve
# to /root if docker compose is ever run with sudo.
#
# Examples:
#   /home/youruser/.cache/huggingface      ← typical single-user setup
#   /mnt/nvme/models/huggingface           ← dedicated model storage volume
#
HF_CACHE_DIR=/home/YOURUSERNAME/.cache/huggingface

# HuggingFace authentication token.
# Required only for gated or private models.
# Qwen2.5-Coder-32B-Instruct-AWQ is public — leave this commented out.
# Obtain a token at: https://huggingface.co/settings/tokens
#
# HF_TOKEN=hf_your_token_here


# =============================================================================
# OPTIONAL / ADVANCED FEATURES
# =============================================================================
# Uncomment to enable. scripts/deploy/deploy.sh passes these to vLLM only
# when the variable is set and non-empty — leaving them commented means
# the flag is never passed and vLLM uses its own defaults.

# --- Speculative Decoding (reduces latency for short outputs) ----------------
# Runs a small fast draft model to predict tokens, verified by the main model.
# Reduces time-to-first-token and inter-token latency for short completions.
# The draft model loads alongside the main model and consumes additional VRAM.
# NUM_SPECULATIVE_TOKENS: how many tokens to draft per step (4–8 is typical).
#
# SPECULATIVE_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct
# NUM_SPECULATIVE_TOKENS=5

# --- Data Type Override -------------------------------------------------------
# vLLM selects dtype automatically based on quantization (AWQ → float16).
# Only override if you have a specific reason.
#   float16   → standard half-precision
#   bfloat16  → better numerical stability; requires Ampere+ (RTX 30xx/40xx ✓)
#
# DTYPE=bfloat16

# --- Eager Mode (disable CUDA graph capture) ----------------------------------
# vLLM captures CUDA graphs by default for faster steady-state inference.
# Set to true to disable — useful when debugging CUDA errors, slower otherwise.
#
# ENFORCE_EAGER=false

# --- Tool Choice (Function Calling) -------------------------------------------
# Enables support for automated tool calling inside Open WebUI.
# Note: Open WebUI requests "auto" tool choice by default, which will throw validation
# errors in vLLM unless these are enabled (or tools are disabled in the UI).
#
# ENABLE_AUTO_TOOL_CHOICE=false
# TOOL_CALL_PARSER=hermes

# --- Concurrent Sequence Cap --------------------------------------------------
# Maximum sequences processed in a single forward pass (default: auto-tuned).
# Reduce if you see instability under many simultaneous connections.
#
# MAX_NUM_SEQS=64


# =============================================================================
# vLLM RESTART POLICY — auto-start after reboot
# =============================================================================

# Docker restart policy for the vLLM container.
# Supported values: no, on-failure, unless-stopped, always
VLLM_RESTART_POLICY=unless-stopped


# =============================================================================
# OPTIONAL OPEN WEBUI SUPPORT
# =============================================================================

# ENABLE_OPEN_WEBUI — set to true to deploy Open WebUI alongside vLLM.
# Defaults to false.
ENABLE_OPEN_WEBUI=false

# OPEN_WEBUI_IMAGE — the Open WebUI Docker image/tag to pull.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# OPEN_WEBUI_CONTAINER_NAME — name of the Open WebUI container.
OPEN_WEBUI_CONTAINER_NAME=open-webui

# OPEN_WEBUI_HOST — interface IP on the host where Open WebUI will bind.
# Set to 0.0.0.0 for LAN access, 127.0.0.1 for localhost only.
OPEN_WEBUI_HOST=0.0.0.0

# OPEN_WEBUI_PORT — the port on the host where Open WebUI will listen.
OPEN_WEBUI_PORT=3000

# OPEN_WEBUI_DATA_VOLUME — named Docker volume for Open WebUI persistent database/data.
OPEN_WEBUI_DATA_VOLUME=open-webui-data

# OPEN_WEBUI_OPENAI_API_BASE_URL — inner network API URL Open WebUI uses to connect to vLLM.
# Since Open WebUI and vLLM share the Docker network, use the service name "vllm".
OPEN_WEBUI_OPENAI_API_BASE_URL=http://vllm:8000/v1

# OPEN_WEBUI_OPENAI_API_KEY — optional API key for vLLM authorization (if configured).
OPEN_WEBUI_OPENAI_API_KEY=""

# OPEN_WEBUI_RESTART_POLICY — Docker restart policy for Open WebUI container.
# Values: no, on-failure, unless-stopped, always
OPEN_WEBUI_RESTART_POLICY=unless-stopped
